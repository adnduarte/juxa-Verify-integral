{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the JUXA platform.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["ADMIN", "INVESTIGADOR", "CLIENTE"],
          "description": "Role of the user in the system."
        },
        "clientType": {
          "type": "string",
          "enum": ["GRATUITO", "BOLSA", "SUSCRIPCION"],
          "description": "Type of client billing scheme."
        },
        "clientProfile": {
          "type": "string",
          "enum": ["GENERAL", "HR", "CREDIT"],
          "description": "Profile of the client to show dynamic forms."
        },
        "credits": {
          "type": "number",
          "description": "Number of investigations available."
        },
        "companyId": {
          "type": "string",
          "description": "Optional ID to group users by company."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "role", "clientType", "credits", "createdAt"]
    },
    "Investigation": {
      "title": "Investigation",
      "description": "An investigation requested by a client or admin.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "clientId": {
          "type": "string",
          "description": "UID of the client who owns this investigation."
        },
        "requestedBy": {
          "type": "string",
          "description": "UID of the user (client or admin) who requested it."
        },
        "status": {
          "type": "string",
          "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "REQUIRES_ATTENTION"]
        },
        "title": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "result": {
          "type": "string"
        },
        "clientProfile": {
          "type": "string",
          "enum": ["GENERAL", "HR", "CREDIT"]
        },
        "creditStage": {
          "type": "string",
          "enum": ["PRE_QUALIFICATION", "QUALIFICATION"]
        },
        "isDirect": {
          "type": "boolean"
        },
        "jobProfile": {
          "type": "string",
          "description": "HR specific: Job description"
        },
        "cvFileName": {
          "type": "string",
          "description": "HR specific: CV file name"
        },
        "smartValidationRequested": {
          "type": "boolean",
          "description": "HR specific: Request AI validation"
        },
        "score": {
          "type": "number",
          "description": "Intelligent score (0-100) generated by AI."
        },
        "scoreBreakdown": {
          "type": "string",
          "description": "JSON stringified breakdown of the score components."
        },
        "visitAddress": {
          "type": "string",
          "description": "Credit specific: Address to visit"
        },
        "contactInfo": {
          "type": "string",
          "description": "Credit specific: Contact information"
        },
        "creditAppFileName": {
          "type": "string",
          "description": "Credit specific: Credit application file name"
        },
        "candidateEmail": {
          "type": "string",
          "description": "Email of the candidate to send the link to"
        },
        "candidatePhone": {
          "type": "string",
          "description": "Phone of the candidate to send the link to"
        },
        "candidateLink": {
          "type": "string",
          "description": "Unique link ID for the candidate"
        },
        "linkStatus": {
          "type": "string",
          "enum": ["PENDING", "OPENED", "IN_PROGRESS", "PHASE_1_COMPLETED", "COMPLETED"],
          "description": "Status of the candidate's link flow"
        },
        "identityValidationResult": {
          "type": "string",
          "description": "JSON stringified results of the AI identity validation"
        },
        "creditAnalysisResult": {
          "type": "string",
          "description": "JSON stringified results of the AI credit analysis"
        },
        "providerAnalysisResult": {
          "type": "string",
          "description": "JSON stringified results of the AI provider analysis"
        },
        "socioeconomicDictamen": {
          "type": "string",
          "description": "JSON stringified results of the AI socioeconomic dictamen"
        },
        "uploadedFileUrls": {
          "type": "object",
          "description": "Map of file labels to their storage URLs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isTest": {
          "type": "boolean",
          "description": "Flag to identify test investigations."
        },
        "loongMontoTotal": {
          "type": "number",
          "description": "Total amount to finance for Loong Motor."
        },
        "loongEnganche": {
          "type": "number",
          "description": "Down payment percentage for Loong Motor."
        },
        "linkId": {
          "type": "string",
          "description": "The ID of the candidate link associated with this investigation."
        }
      },
      "required": ["id", "clientId", "requestedBy", "status", "title", "createdAt", "updatedAt"]
    },
    "Case": {
      "title": "Case",
      "description": "A legal case or diagnostic file.",
      "type": "object",
      "properties": {
        "caseId": {
          "type": "string"
        },
        "ownerUid": {
          "type": "string",
          "description": "UID of the user who created the case."
        },
        "status": {
          "type": "string",
          "enum": ["DRAFT", "DIAGNOSIS", "IN_PROGRESS", "COMPLETED"]
        },
        "dataIA": {
          "type": "string",
          "description": "JSON stringified results of the AI diagnosis."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["caseId", "ownerUid", "status", "createdAt", "updatedAt"]
    },
    "CandidateLink": {
      "title": "Candidate Link",
      "description": "A shareable link for a candidate to fill out their information.",
      "type": "object",
      "properties": {
        "linkId": {
          "type": "string"
        },
        "investigationId": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "clientProfile": {
          "type": "string",
          "enum": ["GENERAL", "HR", "CREDIT"]
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["PENDING", "OPENED", "IN_PROGRESS", "PHASE_1_COMPLETED", "COMPLETED"]
        },
        "candidateData": {
          "type": "string",
          "description": "JSON stringified data submitted by the candidate"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isTest": {
          "type": "boolean",
          "description": "Flag to identify test links."
        },
        "isPreQual": {
          "type": "boolean",
          "description": "Flag to identify pre-qualification links."
        },
        "loongMontoTotal": {
          "type": "number"
        },
        "loongEnganche": {
          "type": "number"
        }
      },
      "required": ["linkId", "investigationId", "clientId", "status", "createdAt", "updatedAt"]
    },
    "PricingPlan": {
      "title": "Pricing Plan",
      "description": "Subscription plans for the SaaS.",
      "type": "object",
      "properties": {
        "planName": {
          "type": "string"
        },
        "max_diagnostics_monthly": {
          "type": "number"
        },
        "feature_access": {
          "type": "boolean"
        }
      },
      "required": ["planName", "max_diagnostics_monthly", "feature_access"]
    },
    "Client": {
      "title": "Client",
      "description": "A corporate client using the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "politicasGenerales": { "type": "string" },
        "scoringConfig": {
          "type": "object",
          "description": "Custom scoring configuration for credit analysis.",
          "properties": {
            "minIncome": { "type": "number" },
            "maxDistance": { "type": "number" },
            "requiredDocs": { "type": "array", "items": { "type": "string" } },
            "weights": {
              "type": "object",
              "properties": {
                "income": { "type": "number" },
                "location": { "type": "number" },
                "documents": { "type": "number" }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Stores corporate client configurations and business rules."
    },
    "/investigations/{investigationId}": {
      "schema": { "$ref": "#/entities/Investigation" },
      "description": "Stores investigations."
    },
    "/cases/{caseId}": {
      "schema": { "$ref": "#/entities/Case" },
      "description": "Stores case files and AI diagnostics."
    },
    "/pricing_plans/{planId}": {
      "schema": { "$ref": "#/entities/PricingPlan" },
      "description": "Stores subscription plans."
    }
  }
}
