rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /candidatos/{investigationId}/{allPaths=**} {
      // Permitir subida pública para el proceso de candidatos no registrados
      // Esto es necesario si el inicio de sesión anónimo tarda o falla
      allow write: if true;
      // Solo usuarios autenticados pueden leer
      allow read: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
