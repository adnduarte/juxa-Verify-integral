rules_version = '2';

// =============================================================================
// MODO DESARROLLO LOCAL — sin restricciones (lectura/escritura abiertas).
// Antes de producción: restaurar reglas desde firestore.rules.production
//   firebase deploy --only firestore:rules
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
